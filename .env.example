# Shopify Storefront API (required for product/cart)
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# Judge.me (server-only) — see https://judge.me/api/docs
# Use the PRIVATE API token (Integrations → Developers / API). The public token is for
# storefront widgets; GET /api/v1/reviews is documented as requiring private auth.
JUDGEME_API_KEY=
# Usually your Shopify domain (falls back to NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN if unset)
JUDGEME_SHOP_DOMAIN=
# Optional: substring to match in the Shopify product title (default: membership)
# JUDGEME_MEMBERSHIP_TITLE_KEYWORD=membership
